# DocuRidge — environment configuration template.
# Copy to .env on first boot. The compose entrypoint will fill in
# any blank required values that have safe randomized defaults
# (BOOTSTRAP_TOKEN, SESSION_SECRET, JWS_SIGNING_TOKEN_SECRET).

# ─── Public URL (canonical absolute base used in emails & token URLs) ───
PUBLIC_URL=http://localhost:3737

# ─── Compose project ────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=docuridge

# ─── Host port bindings (only postgres/mailhog bind to 127.0.0.1) ───────
APP_INTERNAL_PORT=3000             # inside container; reverse proxy reaches via docker network
POSTGRES_HOST_PORT=54317
MAILHOG_UI_HOST_PORT=8737
MAILHOG_SMTP_HOST_PORT=10737

# ─── Database ───────────────────────────────────────────────────────────
POSTGRES_DB=docuridge
POSTGRES_USER=docuridge
POSTGRES_PASSWORD=change-me-in-real-deploy
DATABASE_URL=postgresql://docuridge:change-me-in-real-deploy@docuridge_postgres:5432/docuridge?schema=public

# ─── Mail backend ───────────────────────────────────────────────────────
# Options: mailhog | smtp_relay
MAIL_BACKEND=mailhog

# MailHog (dev default)
MAILHOG_HOST=docuridge_mailhog
MAILHOG_PORT=1025

# Production SMTP relay (only used when MAIL_BACKEND=smtp_relay; allowlist enforced in code)
SMTP_RELAY_HOST=
SMTP_RELAY_PORT=25

# Default From address (org branding overrides per-org)
MAIL_FROM_DEFAULT="DocuRidge <docuridge@example.com>"

# Recipient allowlist — comma-separated. Empty = nothing sends in smtp_relay mode.
# This is a code-level safety net; see DEPLOYMENT.md for removal procedure.
MAIL_ALLOWLIST=

# ─── Cryptographic secrets ──────────────────────────────────────────────
# All three are auto-generated by docker-entrypoint.sh on first boot
# if absent. Rotate by replacing the value and restarting.

SESSION_SECRET=                 # 32-byte random base64 — server-side session signing
JWS_SIGNING_TOKEN_SECRET=       # 32-byte random base64 — signs recipient signing tokens
JWS_RESET_TOKEN_SECRET=         # 32-byte random base64 — signs password-reset/email-verify tokens

# Bootstrap admin token — gates the one-time /setup route
BOOTSTRAP_TOKEN=                # auto-generated on first boot if blank
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_NAME="DocuRidge Admin"
BOOTSTRAP_ORG_NAME="Acme Org"
BOOTSTRAP_ORG_SLUG="acme"

# ─── Auth policy ────────────────────────────────────────────────────────
SESSION_TTL_HOURS=12
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW_MINUTES=15
LOCKOUT_DURATION_MINUTES=15
PASSWORD_MIN_LENGTH=12

# ─── Rate limits (in-process token bucket; per-IP unless noted) ─────────
RL_LOGIN_PER_MIN=10
RL_REGISTER_PER_MIN=5
RL_PASSWORD_RESET_PER_MIN=3
RL_SIGNING_TOKEN_PER_MIN=30

# ─── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=info                  # trace | debug | info | warn | error | fatal
NODE_ENV=production

# ─── Storage (local filesystem in v1) ───────────────────────────────────
UPLOADS_DIR=/data/uploads
SEALED_DIR=/data/sealed
KEYS_DIR=/data/keys
MAX_UPLOAD_BYTES=26214400        # 25 MB
