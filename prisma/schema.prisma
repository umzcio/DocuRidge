// DocuRidge — Prisma schema
// Faithful to SCHEMA.md. v1 model covering every mandatory feature including
// templates and bulk send. Every domain row is org-scoped.
//
// Audit-log integrity: AuditEvent has prevHash + eventHash + signature.
// Append-only enforced at the DB role level via a migration that creates
// a separate role with INSERT/SELECT only on audit_event.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────

enum OrgRole {
  ADMIN
  SENDER
  VIEWER
}

enum EnvelopeType {
  DOCUMENT
  TEMPLATE
}

enum EnvelopeStatus {
  DRAFT
  SENT
  IN_PROGRESS
  COMPLETED
  DECLINED
  VOIDED
  EXPIRED
}

enum RoutingMode {
  SEQUENTIAL
  PARALLEL
}

enum Privacy {
  ISOLATED
  SHARED
}

enum StorageType {
  LOCAL_FS
  S3
}

enum ScanStatus {
  UNSCANNED
  CLEAN
  INFECTED
  ERROR
}

enum RecipientRole {
  SIGNER
  APPROVER
  WITNESS
  IN_PERSON_SIGNER
  CC
  VIEWER
}

enum ReadStatus {
  NOT_OPENED
  OPENED
}

enum SigningStatus {
  NOT_SIGNED
  SIGNED
  DECLINED
  SKIPPED
}

enum SendStatus {
  NOT_SENT
  SENT
  BOUNCED
  FAILED
}

enum FieldType {
  SIGNATURE
  INITIALS
  DATE
  TEXT
  NUMBER
  CHECKBOX
  RADIO
  DROPDOWN
  EMAIL
  NAME
  JOB_TITLE
  PHONE
  ADDRESS
  COMPANY
  FORMULA
  ATTACHMENT
  APPROVE
  DECLINE
  NOTE
  LINE
  STAMP
  DRAWING
}

enum BulkStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum BulkRowStatus {
  PENDING
  DISPATCHED
  FAILED
  SKIPPED_ALLOWLIST
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────────────────────────────────

model Organisation {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  logoUrl             String?
  // Inline base64 logo (≤200KB) for the email header / signing-page chrome.
  logoBase64          String?
  logoMimeType        String?
  senderEmailFromName String?
  // Custom footer text appended to every outbound notification.
  emailFooter         String?
  /// Org-wide accent color applied to outbound emails (button background,
  /// link color) and the signing-ceremony header. CSS hex like "#2544FB".
  /// Defaults to the project's cobalt accent if unset. Validated in the
  /// branding action so the email templates can interpolate it directly.
  brandColor          String?
  /// Org-wide font used to render typed text fields (Date, Text, Number,
  /// Name, Email, etc.) on sealed PDFs and the signing-ceremony preview.
  /// One of: 'sans' (default, Helvetica), 'serif' (TimesRoman), 'mono'
  /// (Courier). Null = sans.
  defaultFieldFont    String?
  defaultEnvelopeTtl  Int      @default(30)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  members          OrgMember[]
  envelopes        Envelope[]
  folders          Folder[]
  documents        DocumentFile[]
  bulkSendJobs     BulkSendJob[]
  webhooks         WebhookSubscription[]
  apiTokens        ApiToken[]
  emailEvents      EmailEvent[]
  signingKeys      OrgSigningKey[]

  @@map("organisation")
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole
  createdAt DateTime @default(now())

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
  @@map("org_member")
}

// ─────────────────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String?
  mustResetPassword   Boolean   @default(false)
  emailVerifiedAt     DateTime?
  name                String
  failedAttempts      Int       @default(0)
  lockedUntil         DateTime?
  lastSignedInAt      DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  memberships         OrgMember[]
  sessions            Session[]
  passwordResets      PasswordResetToken[]
  emailVerifications  EmailVerificationToken[]
  securityEvents      UserSecurityAuditEvent[]
  envelopesCreated    Envelope[]              @relation("EnvelopeCreatedBy")
  filesUploaded       DocumentFile[]
  foldersCreated      Folder[]
  bulkJobsCreated     BulkSendJob[]
  apiTokens           ApiToken[]
  envelopeShares      EnvelopeShare[]
  envelopeComments    EnvelopeComment[]

  jobTitle            String?
  phone               String?
  address             String?
  company             String?
  /// Saved default signature, applied across every envelope this user signs.
  /// Either or both fields may be set: `defaultSignaturePngBase64` is a drawn
  /// signature, `defaultTypedSignature` is the cursive-rendered name. Same
  /// pattern for initials.
  defaultSignaturePngBase64 String?
  defaultTypedSignature     String?
  defaultInitialsPngBase64  String?
  defaultTypedInitials      String?
  notificationPrefs   Json @default("{\"sentForSignature\":true,\"recipientSigned\":true,\"completed\":true,\"declined\":true,\"reminderDigest\":false}")
  /// Per-user "mark all read" timestamp. The notifications dropdown only shows
  /// audit events with createdAt > this value, so clicking "Clear" never
  /// touches the audit chain — it just bumps the user's cursor forward.
  notificationsClearedAt DateTime?
  // Inline base64 PNG/JPEG (≤200KB enforced at the action). Avoids a file-storage
  // round-trip for v1; production should swap to a Storage URL.
  avatarBase64        String?
  avatarMimeType      String?

  @@index([deletedAt])
  @@map("user")
}

model Session {
  id          String    @id
  userId      String
  orgId       String
  ipAddress   String
  userAgent   String
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("session")
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_token")
}

model EmailVerificationToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_token")
}

model UserSecurityAuditEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  ipAddress String?
  userAgent String?
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([type])
  @@map("user_security_audit_event")
}

// ─────────────────────────────────────────────────────────────────────────
// Envelopes & content
// ─────────────────────────────────────────────────────────────────────────

model Envelope {
  id                 String          @id @default(cuid())
  secondaryId        String          @unique @default(cuid())
  orgId              String
  createdById        String
  folderId           String?
  type               EnvelopeType
  status             EnvelopeStatus  @default(DRAFT)
  title              String
  subject            String?
  message            String?
  templateOriginId   String?
  templateSnapshot   Json?
  /// PowerForms: public-link envelope creation. When enabled on a TEMPLATE
  /// envelope, anyone visiting /form/<publicFormToken> can spin up a fresh
  /// envelope from this template by entering name + email. Token is opaque,
  /// 32 bytes base64url. Disable by setting both back to null/false.
  publicFormToken    String?         @unique
  publicFormEnabled  Boolean         @default(false)
  routingMode        RoutingMode     @default(SEQUENTIAL)
  recipientPrivacy   Privacy         @default(ISOLATED)
  expiresAt          DateTime?
  sentAt             DateTime?
  completedAt        DateTime?
  voidedAt           DateTime?
  voidReason         String?
  declinedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  org           Organisation     @relation(fields: [orgId], references: [id], onDelete: Restrict)
  createdBy     User             @relation("EnvelopeCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  folder        Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  templateOrigin Envelope?       @relation("EnvelopeTemplate", fields: [templateOriginId], references: [id], onDelete: SetNull)
  instantiations Envelope[]      @relation("EnvelopeTemplate")
  items         EnvelopeItem[]
  recipients    Recipient[]
  fields        Field[]
  meta          EnvelopeMeta?
  auditEvents   AuditEvent[]
  sealed        SealedDocument?
  emailEvents   EmailEvent[]
  shares        EnvelopeShare[]
  comments      EnvelopeComment[]
  templateLink  TemplateDirectLink?

  @@index([orgId, status, createdAt])
  @@index([orgId, deletedAt])
  @@index([createdById])
  @@index([templateOriginId])
  @@map("envelope")
}

model EnvelopeItem {
  id              String  @id @default(cuid())
  envelopeId      String
  documentFileId  String
  order           Int
  title           String
  pageCount       Int     @default(0)

  envelope     Envelope     @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  documentFile DocumentFile @relation(fields: [documentFileId], references: [id], onDelete: Restrict)
  fields       Field[]

  @@unique([envelopeId, order])
  @@index([envelopeId])
  @@map("envelope_item")
}

model DocumentFile {
  id            String      @id @default(cuid())
  orgId         String
  storageType   StorageType @default(LOCAL_FS)
  storagePath   String
  mimeType      String
  sizeBytes     Int
  sha256        String
  uploadedById  String?
  scanStatus    ScanStatus  @default(UNSCANNED)
  scannedAt     DateTime?
  createdAt     DateTime    @default(now())
  deletedAt     DateTime?

  org             Organisation     @relation(fields: [orgId], references: [id], onDelete: Restrict)
  uploadedBy      User?            @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  envelopeItems   EnvelopeItem[]
  sealedDocuments SealedDocument[]

  @@index([orgId])
  @@index([sha256])
  @@map("document_file")
}

model Recipient {
  id                       String         @id @default(cuid())
  envelopeId               String
  email                    String
  name                     String
  roleLabel                String?
  recipientRole            RecipientRole  @default(SIGNER)
  signingOrder             Int
  readStatus               ReadStatus     @default(NOT_OPENED)
  signingStatus            SigningStatus  @default(NOT_SIGNED)
  sendStatus               SendStatus     @default(NOT_SENT)
  tokenJti                 String?        @unique
  currentTokenExpiresAt    DateTime?
  sentAt                   DateTime?
  openedAt                 DateTime?
  signedAt                 DateTime?
  declinedAt               DateTime?
  declineReason            String?
  expiresAt                DateTime?
  lastReminderSentAt       DateTime?
  nextReminderAt           DateTime?
  ipAddress                String?
  userAgent                String?
  consentGivenAt           DateTime?
  consentDisclosureVersion String?
  /// Optional sender-configured per-recipient metadata. Currently houses the
  /// conditional-routing rule: { condition: { whenFieldId, equals } } —
  /// recipient is only routed when the source field value matches.
  meta                     Json?

  envelope   Envelope    @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  fields      Field[]
  signatures  Signature[]
  attachments FieldAttachment[]
  comments    EnvelopeComment[]

  @@index([envelopeId, signingOrder])
  @@index([email])
  @@index([signingStatus])
  @@map("recipient")
}

model Field {
  id              String    @id @default(cuid())
  envelopeId      String
  envelopeItemId  String
  recipientId     String
  type            FieldType
  page            Int
  x               Decimal   @db.Decimal(8, 6)
  y               Decimal   @db.Decimal(8, 6)
  w               Decimal   @db.Decimal(8, 6)
  h               Decimal   @db.Decimal(8, 6)
  required        Boolean   @default(true)
  defaultValue    String?
  meta            Json?
  value           String?
  filledAt        DateTime?
  order           Int       @default(0)

  envelope     Envelope     @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  envelopeItem EnvelopeItem @relation(fields: [envelopeItemId], references: [id], onDelete: Cascade)
  recipient    Recipient    @relation(fields: [recipientId], references: [id], onDelete: Restrict)
  signature    Signature?
  attachment   FieldAttachment?

  @@index([envelopeId, recipientId])
  @@index([envelopeItemId, page])
  @@map("field")
}

/// Recipient-uploaded supporting file attached to an ATTACHMENT-typed Field.
/// One row per field — replacing an attachment overwrites the row. The file
/// itself lives in storage; this row holds the metadata + storage path.
model FieldAttachment {
  id           String   @id @default(cuid())
  fieldId      String   @unique
  recipientId  String
  filename     String
  mimeType     String
  sizeBytes    Int
  sha256       String
  storagePath  String
  uploadedAt   DateTime @default(now())

  field     Field     @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  recipient Recipient @relation(fields: [recipientId], references: [id], onDelete: Restrict)

  @@map("field_attachment")
}

model Signature {
  id               String   @id @default(cuid())
  recipientId      String
  fieldId          String?  @unique
  imagePngBase64   String?
  typedSignature   String?
  /// Font key picked when adopting a typed signature: 'caveat' (default,
  /// natural handwriting), 'dancing' (flowing cursive), 'great-vibes'
  /// (formal calligraphy), or 'sacramento' (looped script). Null = default.
  typedFont        String?
  capturedAt       DateTime @default(now())
  ipAddress        String?
  userAgent        String?

  recipient Recipient @relation(fields: [recipientId], references: [id], onDelete: Restrict)
  field     Field?    @relation(fields: [fieldId], references: [id], onDelete: SetNull)

  @@index([recipientId])
  @@map("signature")
}

model EnvelopeMeta {
  id                String  @id @default(cuid())
  envelopeId        String  @unique
  signaturesAllowed Json    @default("{\"drawn\": true, \"typed\": true, \"uploaded\": false}")
  reminderSettings  Json    @default("{\"daysBeforeFirst\": 3, \"daysBetween\": 3, \"maxReminders\": 3}")
  emailSubject      String?
  language          String  @default("en-US")
  redirectUrl       String?

  envelope Envelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)

  @@map("envelope_meta")
}

// ─────────────────────────────────────────────────────────────────────────
// Audit chain (the differentiator)
// ─────────────────────────────────────────────────────────────────────────

model AuditEvent {
  id              String   @id @default(cuid())
  envelopeId      String
  seq             Int
  type            String
  actorUserId     String?
  actorRecipientId String?
  actorEmail      String?
  actorName       String?
  ipAddress       String?
  userAgent       String?
  data            Json?
  prevHash        String
  eventHash       String   @unique
  signature       String   @default("")
  signedByKeyId   String   @default("")
  createdAt       DateTime @default(now())

  envelope Envelope @relation(fields: [envelopeId], references: [id], onDelete: Restrict)

  @@unique([envelopeId, seq])
  @@index([envelopeId, createdAt])
  @@index([type])
  @@map("audit_event")
}

model SealedDocument {
  id                 String   @id @default(cuid())
  envelopeId         String   @unique
  documentFileId     String
  manifestJson       Json
  manifestSignature  String   @default("")
  chainHeadHash      String
  signedByKeyId      String   @default("")
  sealedAt           DateTime @default(now())

  envelope     Envelope     @relation(fields: [envelopeId], references: [id], onDelete: Restrict)
  documentFile DocumentFile @relation(fields: [documentFileId], references: [id], onDelete: Restrict)

  @@map("sealed_document")
}

/// Per-envelope comment / discussion thread. Both senders (via dashboard)
/// and recipients (via signing token) can post. Author is identified by
/// either authorUserId (sender side) or authorRecipientId (recipient side);
/// authorName is denormalized for display so deleted users don't break the
/// thread. Every post is also recorded as a `comment.added` audit event so
/// the chain has the message and the timestamp.
model EnvelopeComment {
  id                String     @id @default(cuid())
  envelopeId        String
  authorUserId      String?
  authorRecipientId String?
  authorName        String
  body              String
  createdAt         DateTime   @default(now())

  envelope        Envelope   @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  authorUser      User?      @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  authorRecipient Recipient? @relation(fields: [authorRecipientId], references: [id], onDelete: SetNull)

  @@index([envelopeId, createdAt])
  @@map("envelope_comment")
}

/// Public view-link for a sealed envelope. Created when the sender uses
/// "Forward" on a COMPLETED envelope; anyone with the token can view +
/// download the sealed PDF until `expiresAt`. Tokens are random 32-byte
/// base64url strings, indexed unique. Visits update `lastViewedAt` and
/// increment `viewCount` so the sender can see if their forward landed.
model EnvelopeShare {
  id            String   @id @default(cuid())
  envelopeId    String
  token         String   @unique
  /// Comma-separated list of email addresses that received the link, for
  /// audit/display only. Anyone with the token can use it.
  recipientEmails String
  /// Optional sender note shown in the forward email.
  note          String?
  createdById   String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  lastViewedAt  DateTime?
  viewCount     Int      @default(0)
  revokedAt     DateTime?

  envelope  Envelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([envelopeId])
  @@map("envelope_share")
}

// ─────────────────────────────────────────────────────────────────────────
// Email tracking
// ─────────────────────────────────────────────────────────────────────────

model EmailEvent {
  id           String   @id @default(cuid())
  orgId        String
  envelopeId   String?
  recipientId  String?
  type         String
  messageId    String?
  subject      String?
  toAddress    String
  error        String?
  data         Json?
  createdAt    DateTime @default(now())

  org      Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  envelope Envelope?    @relation(fields: [envelopeId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([envelopeId])
  @@index([recipientId])
  @@map("email_event")
}

// ─────────────────────────────────────────────────────────────────────────
// Folders & template direct links
// ─────────────────────────────────────────────────────────────────────────

model Folder {
  id          String       @id @default(cuid())
  orgId       String
  parentId    String?
  name        String
  type        EnvelopeType
  createdById String
  createdAt   DateTime     @default(now())
  deletedAt   DateTime?

  org        Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent     Folder?      @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   Folder[]     @relation("FolderTree")
  envelopes  Envelope[]
  createdBy  User         @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([orgId, type])
  @@index([parentId])
  @@map("folder")
}

model TemplateDirectLink {
  id         String   @id @default(cuid())
  envelopeId String   @unique
  token      String   @unique
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())

  envelope Envelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)

  @@map("template_direct_link")
}

// ─────────────────────────────────────────────────────────────────────────
// Bulk send
// ─────────────────────────────────────────────────────────────────────────

model BulkSendJob {
  id                 String     @id @default(cuid())
  orgId              String
  templateEnvelopeId String
  createdById        String
  status             BulkStatus @default(PENDING)
  totalRows          Int
  succeededRows      Int        @default(0)
  failedRows         Int        @default(0)
  csvFilename        String
  csvSha256          String
  createdAt          DateTime   @default(now())
  completedAt        DateTime?

  org       Organisation   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User           @relation(fields: [createdById], references: [id], onDelete: Restrict)
  rows      BulkSendRow[]

  @@index([orgId, createdAt])
  @@index([status])
  @@map("bulk_send_job")
}

model BulkSendRow {
  id             String        @id @default(cuid())
  jobId          String
  rowNumber      Int
  recipientMap   Json
  fieldOverrides Json?
  envelopeId     String?
  status         BulkRowStatus @default(PENDING)
  error          String?

  job BulkSendJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, rowNumber])
  @@map("bulk_send_row")
}

// ─────────────────────────────────────────────────────────────────────────
// Crypto, API tokens, webhooks
// ─────────────────────────────────────────────────────────────────────────

model OrgSigningKey {
  id            String    @id @default(cuid())
  orgId         String
  algorithm     String    @default("ed25519")
  publicKeyPem  String
  keyFilename   String
  fingerprint   String    @unique
  createdAt     DateTime  @default(now())
  revokedAt     DateTime?

  org Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("org_signing_key")
}

model ApiToken {
  id          String    @id @default(cuid())
  orgId       String
  userId      String
  name        String
  tokenHash   String    @unique
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([userId])
  @@map("api_token")
}

model WebhookSubscription {
  id        String   @id @default(cuid())
  orgId     String
  url       String
  events    String[]
  secret    String
  createdAt DateTime @default(now())
  enabled   Boolean  @default(true)

  org   Organisation  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  calls WebhookCall[]

  @@index([orgId])
  @@map("webhook_subscription")
}

model WebhookCall {
  id              String   @id @default(cuid())
  subscriptionId  String
  payload         Json
  responseStatus  Int?
  responseBody    String?
  attempts        Int      @default(0)
  nextRetryAt     DateTime?
  createdAt       DateTime @default(now())

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@map("webhook_call")
}

// ─────────────────────────────────────────────────────────────────────────
// System tables
// ─────────────────────────────────────────────────────────────────────────

model BackgroundJob {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      JobStatus @default(PENDING)
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  runAt       DateTime  @default(now())
  lastError   String?
  lockedBy    String?
  lockedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt])
  @@index([type])
  @@map("background_job")
}

model RateLimit {
  key    String
  action String
  bucket DateTime
  count  Int      @default(0)

  @@id([key, action, bucket])
  @@index([bucket])
  @@map("rate_limit")
}

model BootstrapState {
  id                  Int       @id @default(1)
  pendingAdminUserId  String?
  tokenHash           String
  completedAt         DateTime?
  createdAt           DateTime  @default(now())

  @@map("bootstrap_state")
}
